{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block stylesheets %}
<style>
    .login_form {
        input {
            background-color: #F3F3F5;
            min-width: 398px;
            padding: 12px;
            border-radius: 8px;
        }

        label {
            font-size: 14px;
        }
    }
</style>
{% endblock %}

{% block body %}
<section class="bg-[#EFF6FF] h-screen flex flex-col justify-center items-center ">
    <div class="bg-white p-5">
        <h2 class=" text-base mb-3">Gestion de Tâches</h2>
        <p class="text-base text-[#717182]">Organisez votre journée efficacement</p>
        <div class="flex flex-row rounded-xl justify-between items-center bg-[#ECECF0] p-1">
            <a href="/login" class="flex-1">
                <p class="text-sm  text-center bg-white p-2 rounded-xl">Connexion</p>
            </a>
            <a href="/register" class="flex-1">
                <p class="text-sm  text-center ">Inscription</p>
            </a>
        </div>
        <form method="post" class="login_form flex flex-col">
            {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
            <div class="mb-3">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
            {% endif %}


            <label for="username">Email</label>
            <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control "
                autocomplete="email" required autofocus placeholder="votre@email.com">
            <label for="password">Mot de passe</label>
            <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password"
                required placeholder="*******">
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                value="{{ csrf_token('authenticate') }}">

            {#
            Uncomment this section and add a remember_me option below your firewall to activate remember me
            functionality.
            See https://symfony.com/doc/current/security/remember_me.html

            <div class="checkbox mb-3">
                <input type="checkbox" name="_remember_me" id="_remember_me">
                <label for="_remember_me">Remember me</label>
            </div>
            #}

            <button class="btn btn-lg btn-primary bg-[#030213] text-white pt-1 pb-1 rounded-xl mt-5 mb-5" type="submit">
                Se connecter
            </button>
        </form>
    </div>
</section>

{% endblock %}