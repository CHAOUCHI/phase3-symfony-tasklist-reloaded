{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
    .register_form {
        form{
            input {
                background-color: #F3F3F5;
                min-width: 398px;
                padding: 12px;
                border-radius: 8px;
            }
            label{
                font-size: 14px;
            }
            div{
                display: flex;
                flex-direction: column;
            }
        }
    }
</style>
{% endblock %}

{% block title %}Register{% endblock %}
{% block body %}
<section class="bg-[#EFF6FF] h-screen flex flex-col justify-center items-center ">
    <div class="register_form bg-white p-5">
        <h2 class=" text-base mb-3">Gestion de Tâches</h2>
        <p class="text-base text-[#717182]">Organisez votre journée efficacement</p>
        <div class="flex flex-row rounded-xl justify-between items-center bg-[#ECECF0] p-2">
            <p class="text-sm flex-1 text-center">Connexion</p>
            <p class="text-sm  flex-1 rounded-xl text-center bg-white p-2">Inscription</p>
        </div>
        {{ form_start(registrationForm) }}
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.username) }}
        {{ form_row(registrationForm.plainPassword, {
            label: 'Mot de passe'            
        }) }}
        {{ form_row(registrationForm.agreeTerms) }}
        
        <button type="submit" class="btn">Register</button>
        {{ form_end(registrationForm) }}
    </div>
    {{ form_errors(registrationForm) }}
</section>
{% endblock %}